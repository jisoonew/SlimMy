<Window x:Class="SlimMy.View.NoticeDetail"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:SlimMy.ViewModel"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:NoticeDetailViewModel}"
        Title="공지 상세"
        Width="600"
        MinWidth="500"
        MinHeight="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F8F8F8">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                BorderBrush="#E2E2E2"
                BorderThickness="1"
                Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 제목 -->
                <TextBlock Grid.Row="0"
                           Text="{Binding NoticeTitle}"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#222"
                           TextWrapping="Wrap"/>

                <!-- 정보 -->
                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            Margin="0,12,0,0">
                    <Border Background="#FFF4CC"
                            CornerRadius="10"
                            Padding="10,4"
                            Margin="0,0,8,0">
                        <TextBlock Text="{Binding NoticeType}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#8A6700"/>
                    </Border>

                    <Border Background="#F1F1F1"
                            CornerRadius="10"
                            Padding="10,4">
                        <TextBlock Text="{Binding CreatedAtText}"
                                   FontSize="12"
                                   Foreground="#555"/>
                    </Border>
                </StackPanel>

                <!-- 구분선 -->
                <Border Grid.Row="2"
                        Height="1"
                        Background="#E8E8E8"
                        Margin="0,16,0,0"/>

                <!-- 내용 -->
                <ScrollViewer Grid.Row="4"
                              VerticalScrollBarVisibility="Auto"
                              Margin="0,0,0,0">
                    <TextBlock Text="{Binding NoticeContent}"
                               TextWrapping="Wrap"
                               FontSize="15"
                               Foreground="#333"
                               LineHeight="24"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="Transparent"
                Margin="0,12,0,0">
            <DockPanel LastChildFill="False">
                <Button Content="확인"
                        Width="100"
                        Height="36"
                        Command="{Binding CloseCommand}"
                        Background="#EDEDED"
                        Foreground="#333"
                        BorderBrush="#D0D0D0"
                        DockPanel.Dock="Right"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
